{
  "name": "security-and-advanced-typing",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -c \"bgMagenta.bold,bgCyan.bold\" -p \"[{name}]\" -n \"API,WEB\" \"npm run dev --workspace=./packages/api\" \"npm run dev --workspace=./packages/web\"",
    "build": "npm run build --workspace=./packages/shared && npm run build --workspace=./packages/api && npm run build --workspace=./packages/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
